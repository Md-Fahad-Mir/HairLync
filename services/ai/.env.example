OPENAI_API_KEY=mock-key-for-local-dev
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=mock-key-for-local-dev

# Required for specific YouTube video links in tutorials. Without this the
# app falls back to a generic YouTube search-results link instead of a
# direct video. Get a key from https://console.cloud.google.com/apis/credentials
# after enabling "YouTube Data API v3".
YOUTUBE_API_KEY=mock-key-for-local-dev
YOUTUBE_MAX_RESULTS=3
YOUTUBE_SAFE_SEARCH=moderate
YOUTUBE_TIMEOUT=10