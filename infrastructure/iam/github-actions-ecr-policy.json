{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECRGetAuthorizationToken",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "ECRValidateAndPushHairIQImages",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:CompleteLayerUpload",
        "ecr:DescribeRepositories",
        "ecr:GetDownloadUrlForLayer",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart"
      ],
      "Resource": [
        "arn:aws:ecr:eu-north-1:242969681131:repository/hairiq-backend",
        "arn:aws:ecr:eu-north-1:242969681131:repository/hairiq-ai",
        "arn:aws:ecr:eu-north-1:242969681131:repository/hairiq-landing",
        "arn:aws:ecr:eu-north-1:242969681131:repository/hairiq-admin"
      ]
    }
  ]
}
