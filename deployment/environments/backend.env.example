# ═══════════════════════════════════════════════════════════════════════
# HairIQ — Backend Environment Variables Template
# Copy this file and fill in real values. NEVER commit the filled copy.
# ═══════════════════════════════════════════════════════════════════════

# Django Core
DEBUG=False
DJANGO_SECRET_KEY=generate-a-strong-secret-key-here
DJANGO_ALLOWED_HOSTS=api.hairlync.com,localhost,127.0.0.1
DJANGO_DEBUG=False

# PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=hairiq
DB_USER=hairiq_admin
DB_PASSWORD=your-strong-db-password
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@hairlync.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@hairlync.com

# AI Service Integration
AI_API_URL=http://ai:8001/analyze

# AWS S3 (optional — for production media storage)
USE_S3=True
AWS_STORAGE_BUCKET_NAME=hairiq-media-prod
AWS_S3_REGION_NAME=your-region
AWS_LOCATION=media
AWS_QUERYSTRING_AUTH=False
SYNC_MEDIA_TO_S3_ON_START=True
# Leave access keys empty when using an EC2/ECS IAM role with S3 permissions.
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# CORS
CORS_ALLOWED_ORIGINS=https://hairlync.com,https://admin.hairlync.com,http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=https://api.hairlync.com,https://hairlync.com,https://admin.hairlync.com,http://localhost:8000,http://127.0.0.1:8000

# Django Superuser (initial setup only)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@hairlync.com
DJANGO_SUPERUSER_PASSWORD=use-a-strong-password
