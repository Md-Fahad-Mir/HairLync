# ═══════════════════════════════════════════════════════════════════════
# HairIQ — AI Service Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════

# ── Required API Keys ──
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── YouTube Data API v3 (required for specific video links) ──
# Without this key, tutorial suggestions fall back to a generic YouTube
# search-results link instead of a direct video link. Enable "YouTube Data
# API v3" and create a key at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_MAX_RESULTS=3
YOUTUBE_SAFE_SEARCH=moderate
YOUTUBE_TIMEOUT=10

# ── Server ──
HOST=0.0.0.0
PORT=8001
APP_ENV=production
RELOAD=false
MAX_UPLOAD_MB=10

# ── CORS ──
CORS_ORIGINS=https://hairlync.com,https://api.hairlync.com,https://admin.hairlync.com

# ── Tailscale (optional, for internal access) ──
# TAILSCALE_HOST=your-tailscale-hostname
# TAILSCALE_URL=http://your-tailscale-hostname:8001
