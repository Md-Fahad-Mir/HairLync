# ═══════════════════════════════════════════════════════════════════════
# HairIQ — AI Service Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════

# ── Required API Keys ──
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Server ──
HOST=0.0.0.0
PORT=8001
APP_ENV=production
RELOAD=false

# ── CORS ──
CORS_ORIGINS=https://hairlync.com,https://api.hairlync.com,https://admin.hairlync.com

# ── Tailscale (optional, for internal access) ──
# TAILSCALE_HOST=your-tailscale-hostname
# TAILSCALE_URL=http://your-tailscale-hostname:8001
